# Core
APP_NAME=Gym API
APP_ENV=development
APP_DEBUG=true
API_V1_PREFIX=/v1
SECRET_KEY=change_me_super_secret_and_long
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Database
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=gym_api
POSTGRES_USER=gym_user
POSTGRES_PASSWORD=gym_pass
DATABASE_URL=postgresql+psycopg://gym_user:gym_pass@db:5432/gym_api

# Redis
REDIS_URL=redis://redis:6379/0
ALLOW_INMEMORY_RATE_LIMIT_FALLBACK=false

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

# Security and anti-abuse
ENABLE_EMAIL_VERIFICATION=true
MAX_LOGIN_ATTEMPTS_PER_15_MIN=10
MAX_REGISTER_ATTEMPTS_PER_HOUR=10
MAX_PLAN_GENERATIONS_PER_MIN=20
FREE_COOLDOWN_DAYS=15
ENABLE_SQL_IMPORT_ENDPOINT=false
ADMIN_IMPORT_KEY=change_me_admin_import_key

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_PATH=./storage
PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media

# Payments
PAYMENT_PROVIDER=stripe
PAYMENT_WEBHOOK_SECRET=change_me

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
